DATABASE_URL=postgresql+asyncpg://localhost:5432/pingcrm
REDIS_URL=redis://localhost:6379/0
# REQUIRED: Generate with `python -c "import secrets; print(secrets.token_urlsafe(64))"`
SECRET_KEY=
# REQUIRED: Generate with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=
# Set to "production" in production deployments (enforces mandatory security checks)
ENVIRONMENT=development
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:3000/auth/twitter/callback
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
ANTHROPIC_API_KEY=
# Preferred AI provider (OpenAI). Set this to use OpenAI instead of Anthropic.
OPENAI_API_KEY=

# Bird CLI — Twitter/X cookie-based access (optional)
# Extract from browser: DevTools → Application → Cookies → x.com
AUTH_TOKEN=
CT0=
